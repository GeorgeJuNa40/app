# Llaves de conexión a Supabase (Move yA)
# Copia este archivo como ".env.local" y pon tus valores reales.
# La llave anon es pública/segura para el navegador; la RLS protege los datos.
# NUNCA pongas aquí la llave secreta (service_role / sb_secret_...).

VITE_SUPABASE_URL=https://TU-PROYECTO.supabase.co
VITE_SUPABASE_ANON_KEY=tu-llave-anon-public
